---
import IPhoneAppLayout from '../../../layouts/iPhoneAppLayout.astro';
import { labNotes, labPrinciples } from '../../../config/labNotes';

const deepDives = labNotes.filter((note) => note.kind === 'Deep Dive');
const newsItems = labNotes.filter((note) => note.kind === 'News');
---

<IPhoneAppLayout appLabel="Lab Notes">
  <main class="min-h-screen px-4 pb-24 pt-24 text-white sm:px-6">
    <h1 class="text-2xl font-semibold">Lab Notes</h1>
    <p class="mt-2 text-white/70">
      Research writing and engineering notes focused on intent, memory, and empowerment-first
      systems.
    </p>

    <section class="mt-5 rounded-2xl border border-white/10 bg-white/5 p-4">
      <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-white/65">Principles</h2>
      <div class="mt-3 space-y-2 text-sm">
        {
          labPrinciples.map((principle) => (
            <div class="flex items-start justify-between gap-4">
              <span class="text-white/50">{principle.label}</span>
              <span class="max-w-[58%] text-right text-white/80">{principle.value}</span>
            </div>
          ))
        }
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <a
          class="rounded-full bg-white/10 px-3 py-1.5 text-sm active:bg-white/20"
          href="https://ai-news-hub.performics-labs.com/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open AI News Hub
        </a>
        <a
          class="rounded-full bg-white/10 px-3 py-1.5 text-sm active:bg-white/20"
          href="/mobile/apps/projects"
        >
          Workbench
        </a>
        <a
          class="rounded-full bg-white/10 px-3 py-1.5 text-sm active:bg-white/20"
          href="/mobile/apps/network"
        >
          Network
        </a>
        <a
          class="rounded-full bg-white/10 px-3 py-1.5 text-sm active:bg-white/20"
          href="/mobile/apps/terminal"
        >
          Terminal
        </a>
      </div>
    </section>

    <section class="mt-6">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-white/65">
          Pinned Deep Dives
        </h2>
        <span class="text-[10px] text-white/35">{deepDives.length} notes</span>
      </div>

      <div class="mt-3 space-y-3">
        {
          deepDives.map((note) => (
            <a
              class="block rounded-2xl border border-white/10 bg-white/5 p-4 active:bg-white/10 transition"
              href={note.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-base font-semibold">{note.title}</h3>
                  <p class="text-xs text-white/60">{note.subtitle}</p>
                </div>
                <span class="rounded-full border border-white/10 bg-black/30 px-2 py-1 text-[10px] text-white/65">
                  {note.readingTime}
                </span>
              </div>
              <div class="mt-3 flex flex-wrap gap-2">
                {note.tags.map((tag) => (
                  <span class="rounded-full border border-white/10 bg-black/30 px-2 py-1 text-[10px] text-white/60">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-6">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-white/65">
          News Analysis
        </h2>
        <span class="text-[10px] text-white/35">{newsItems.length} notes</span>
      </div>

      <div class="mt-3 space-y-3">
        {
          newsItems.map((note) => (
            <a
              class="block rounded-2xl border border-white/10 bg-white/5 p-4 active:bg-white/10 transition"
              href={note.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-base font-semibold">{note.title}</h3>
                  <p class="text-xs text-white/60">{note.subtitle}</p>
                </div>
                <span class="rounded-full border border-white/10 bg-black/30 px-2 py-1 text-[10px] text-white/65">
                  {note.readingTime}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</IPhoneAppLayout>
