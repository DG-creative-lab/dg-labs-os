---
import DesktopLayout from '../../layouts/DesktopLayout.astro';
import DraggableAppWindow from '../../components/global/DraggableAppWindow';
import { workbench } from '../../config/workbench';

const toSectionId = (category: string) =>
  `workbench-${category.toLowerCase().replace(/\s+/g, '-')}`;
---

<DesktopLayout activeAppId="projects">
  <main class="relative min-h-[calc(100vh-4rem)] px-6 pt-12 text-white">
    <DraggableAppWindow
      client:load
      appId="projects"
      title="Workbench"
      closeHref="/desktop"
      initialSize={{ width: 980, height: 680 }}
      initialPosition={{ x: 80, y: 80 }}
    >
      <div class="flex items-start justify-between gap-6">
        <div>
          <h1 class="text-2xl font-semibold">Workbench</h1>
          <p class="mt-2 text-white/70">
            Systems and writing built around human agency: intent recognition, learning loops, and
            practical infrastructure.
          </p>
        </div>
        <div class="hidden md:block text-right text-xs text-white/50">
          <p>DG-Labs OS</p>
          <p>Module: Workbench</p>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-1 gap-4">
        {
          ['Research Systems', 'Platforms', 'Writing', 'Hackathons'].map((cat) => {
            const items = workbench.filter((x) => x.category === cat);
            if (items.length === 0) return null;
            return (
              <section id={toSectionId(cat)}>
                <h2 class="text-sm font-semibold tracking-wide text-white/80">{cat}</h2>
                <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-4">
                  {items.map((item) => (
                    <article class="rounded-xl border border-white/10 bg-white/5 p-4 hover:bg-white/7 transition">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <h3 class="text-lg font-semibold">{item.title}</h3>
                          <p class="text-sm text-white/60">{item.subtitle}</p>
                        </div>
                        <span class="text-[10px] uppercase tracking-[0.2em] text-white/40">
                          {item.id}
                        </span>
                      </div>
                      <p class="mt-3 text-sm text-white/75">{item.summary}</p>

                      <div class="mt-3 flex flex-wrap gap-2">
                        {item.stack.slice(0, 6).map((t) => (
                          <span class="text-[11px] rounded-full bg-black/30 border border-white/10 px-2 py-1 text-white/70">
                            {t}
                          </span>
                        ))}
                      </div>

                      <ul class="mt-4 space-y-1 text-sm text-white/70">
                        {item.highlights.slice(0, 4).map((h) => (
                          <li class="flex gap-2">
                            <span class="text-white/40">-</span>
                            <span>{h}</span>
                          </li>
                        ))}
                      </ul>

                      <div class="mt-4 flex flex-wrap gap-2">
                        {item.links.repo && (
                          <a
                            class="text-sm rounded-full bg-white/10 px-3 py-1.5 hover:bg-white/20 transition"
                            href={item.links.repo}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            Repo
                          </a>
                        )}
                        {item.links.article && (
                          <a
                            class="text-sm rounded-full bg-white/10 px-3 py-1.5 hover:bg-white/20 transition"
                            href={item.links.article}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            Article
                          </a>
                        )}
                        {item.links.demo && (
                          <a
                            class="text-sm rounded-full bg-white/10 px-3 py-1.5 hover:bg-white/20 transition"
                            href={item.links.demo}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            Demo
                          </a>
                        )}
                        {item.links.site && (
                          <a
                            class="text-sm rounded-full bg-white/10 px-3 py-1.5 hover:bg-white/20 transition"
                            href={item.links.site}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            Site
                          </a>
                        )}
                      </div>
                    </article>
                  ))}
                </div>
              </section>
            );
          })
        }
      </div>
    </DraggableAppWindow>
  </main>
</DesktopLayout>

<script is:inline>
  const jumpTo = (sectionId) => {
    if (!sectionId) return;
    const el = document.getElementById(sectionId);
    if (!el) return;
    const container = el.closest('.no-scrollbar');
    if (container instanceof HTMLElement) {
      const top = Math.max(0, el.offsetTop - 8);
      container.scrollTo({ top, behavior: 'smooth' });
      return;
    }
    el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  const onWorkbenchMenuAction = (event) => {
    const detail = event.detail;
    if (!detail || !detail.action) return;
    if (detail.action === 'jump_section' && typeof detail.sectionId === 'string') {
      jumpTo(detail.sectionId);
      return;
    }
    if (detail.action === 'scroll_top') {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  };

  window.addEventListener('dg-workbench-menu-action', onWorkbenchMenuAction);
</script>
