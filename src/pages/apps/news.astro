---
import DesktopLayout from '../../layouts/DesktopLayout.astro';
import DraggableAppWindow from '../../components/global/DraggableAppWindow';
---

<DesktopLayout activeAppId="news">
  <main class="relative min-h-[calc(100vh-4rem)] px-6 pt-12 text-white">
    <DraggableAppWindow
      client:load
      appId="news"
      title="AI News Hub"
      closeHref="/desktop"
      initialSize={{ width: 780, height: 500 }}
      initialPosition={{ x: 150, y: 120 }}
    >
      <h1 class="text-2xl font-semibold">AI News Hub</h1>
      <p class="mt-3 text-white/70">Your research writing and analysis lives here.</p>
      <a
        class="mt-4 inline-flex items-center rounded-full bg-white/10 px-4 py-2 text-sm text-white hover:bg-white/20 transition"
        href="https://ai-news-hub.performics-labs.com/"
        target="_blank"
        rel="noopener noreferrer"
      >
        Open Site
      </a>
    </DraggableAppWindow>
  </main>
</DesktopLayout>
