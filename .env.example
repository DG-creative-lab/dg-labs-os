# ============================================
# Portfolio Environment Variables
# ============================================
#
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# --------------------------------------------
# Required: AI Chat Integration (at least one provider key)
# --------------------------------------------
# Get your OpenRouter API key from: https://openrouter.ai/keys
# This enables the interactive terminal chatbot feature
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional additional server-owned providers
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Note:
# - Agents Terminal supports BYOK in-session (and optional local browser persistence).
# - Provider fallback only works when an alternate provider key is available.

# --------------------------------------------
# Optional: Site Configuration
# --------------------------------------------
# Your production website URL (used for SEO and request headers)
# PUBLIC_SITE_URL=https://your-domain.tld
#
# Optional site name for OpenRouter request headers
# PUBLIC_SITE_NAME=DG-Labs OS

# --------------------------------------------
# Optional: Contact API storage (Supabase)
# --------------------------------------------
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
